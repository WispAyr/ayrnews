<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AyrNews — Ayrshire News Hub</title>
<meta name="description" content="Local news hub for Ayrshire, Scotland. Live weather, warnings, and curated news from BBC Scotland, The Guardian, STV, and more.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  --bg: #0a0b10;
  --bg-surface: #12131a;
  --bg-card: #181a24;
  --bg-card-hover: #1e2130;
  --bg-header: rgba(10, 11, 16, 0.88);
  --bg-pill: rgba(255,255,255,0.06);
  --bg-pill-active: #3b82f6;
  --text: #eaecf0;
  --text-secondary: #9094a6;
  --text-muted: #5c6078;
  --border: rgba(255,255,255,0.06);
  --accent: #3b82f6;
  --accent-green: #10b981;
  --accent-amber: #f59e0b;
  --accent-red: #ef4444;
  --accent-cyan: #06b6d4;
  --shadow: 0 1px 3px rgba(0,0,0,0.3);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.5);
  --radius: 14px;
  --radius-sm: 10px;
  --max-w: 1280px;
}

[data-theme="light"] {
  --bg: #f3f4f8;
  --bg-surface: #ecedf2;
  --bg-card: #ffffff;
  --bg-card-hover: #f7f8fc;
  --bg-header: rgba(243, 244, 248, 0.92);
  --bg-pill: rgba(0,0,0,0.05);
  --bg-pill-active: #3b82f6;
  --text: #12131a;
  --text-secondary: #5c6078;
  --text-muted: #9094a6;
  --border: rgba(0,0,0,0.07);
  --shadow: 0 1px 3px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.08);
}

html { scroll-behavior: smooth; }
body {
  font-family: var(--font);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  transition: background 0.3s, color 0.3s;
  -webkit-font-smoothing: antialiased;
}
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* ===== Warning Banner ===== */
.warning-banner {
  background: linear-gradient(90deg, #b45309, #d97706);
  color: #fff;
  padding: 0;
  font-size: 0.82rem;
  font-weight: 600;
  overflow: hidden;
  display: none;
  position: relative;
}
.warning-banner.active { display: block; }
.warning-banner .banner-track {
  display: flex;
  align-items: center;
  gap: 2rem;
  padding: 0.55rem 1.5rem;
  white-space: nowrap;
  animation: scroll-left 30s linear infinite;
}
.warning-banner .banner-track:hover { animation-play-state: paused; }
.warning-banner .warn-icon { font-size: 1rem; flex-shrink: 0; }
.warning-banner a { color: #fff; text-decoration: underline; }
@keyframes scroll-left {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
.warning-banner.warning-red { background: linear-gradient(90deg, #b91c1c, #dc2626); }

/* ===== Header ===== */
.header {
  position: sticky; top: 0; z-index: 100;
  background: var(--bg-header);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--border);
  padding: 0 1.5rem;
}
.header-inner {
  max-width: var(--max-w); margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 60px; gap: 1rem;
}
.brand {
  display: flex; align-items: center; gap: 0.6rem;
  font-weight: 800; font-size: 1.2rem;
  color: var(--text); text-decoration: none;
}
.brand:hover { text-decoration: none; }
.brand-icon { font-size: 1.4rem; }
.brand-sub {
  font-size: 0.65rem; font-weight: 500;
  color: var(--text-muted); letter-spacing: 0.03em;
  text-transform: uppercase;
}
.header-right { display: flex; align-items: center; gap: 0.6rem; }

.wispayr-link {
  font-size: 0.78rem; color: var(--text-secondary);
  padding: 0.3rem 0.7rem; border-radius: 8px;
  background: var(--bg-pill); transition: all 0.2s;
  font-weight: 500;
}
.wispayr-link:hover { background: var(--accent); color: #fff; text-decoration: none; }

.icon-btn {
  background: var(--bg-pill); border: none; cursor: pointer;
  width: 34px; height: 34px; border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; transition: all 0.2s;
  color: var(--text-secondary);
}
.icon-btn:hover { background: var(--accent); color: #fff; }

/* ===== Context Bar ===== */
.context-bar {
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border);
  padding: 0.65rem 1.5rem;
  overflow-x: auto;
}
.context-inner {
  max-width: var(--max-w); margin: 0 auto;
  display: flex; align-items: center; gap: 1.25rem;
  min-width: max-content;
}
.ctx-item {
  display: flex; align-items: center; gap: 0.4rem;
  font-size: 0.78rem; color: var(--text-secondary);
  white-space: nowrap;
}
.ctx-item .ctx-icon { font-size: 0.9rem; }
.ctx-item .ctx-value { font-weight: 700; color: var(--text); }
.ctx-item .ctx-label { color: var(--text-muted); font-size: 0.72rem; }
.ctx-sep { width: 1px; height: 18px; background: var(--border); flex-shrink: 0; }

/* ===== Stats + Filters row ===== */
.toolbar {
  max-width: var(--max-w); margin: 1rem auto 0;
  padding: 0 1.5rem;
  display: flex; align-items: center; gap: 0.75rem;
  flex-wrap: wrap;
}
.stat-chip {
  display: flex; align-items: center; gap: 0.35rem;
  background: var(--bg-card); border-radius: var(--radius-sm);
  padding: 0.35rem 0.7rem; font-size: 0.78rem;
  border: 1px solid var(--border);
}
.stat-chip .num { font-weight: 700; color: var(--accent); }
.stat-chip .lbl { color: var(--text-secondary); }

.toolbar-spacer { flex: 1; }

.filter-btn {
  background: var(--bg-pill); border: 1px solid transparent;
  color: var(--text-secondary); cursor: pointer;
  padding: 0.4rem 0.9rem; border-radius: var(--radius-sm);
  font-family: var(--font); font-size: 0.82rem; font-weight: 500;
  transition: all 0.2s;
}
.filter-btn:hover { background: var(--bg-card-hover); color: var(--text); }
.filter-btn.active {
  background: var(--bg-pill-active); color: #fff;
  border-color: var(--accent);
}

.search-box {
  position: relative;
}
.search-box input {
  background: var(--bg-card); border: 1px solid var(--border);
  color: var(--text); font-family: var(--font); font-size: 0.82rem;
  padding: 0.4rem 0.7rem 0.4rem 2rem;
  border-radius: var(--radius-sm); width: 200px;
  transition: all 0.2s;
}
.search-box input:focus { outline: none; border-color: var(--accent); width: 260px; }
.search-box::before {
  content: '\1F50D'; position: absolute; left: 0.6rem; top: 50%;
  transform: translateY(-50%); font-size: 0.8rem; pointer-events: none;
}

.refresh-info {
  font-size: 0.72rem; color: var(--text-muted);
  display: flex; align-items: center; gap: 0.35rem;
}
.pulse {
  display: inline-block; width: 7px; height: 7px;
  background: var(--accent-green); border-radius: 50%;
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

/* ===== Grid ===== */
.grid {
  max-width: var(--max-w); margin: 1.25rem auto 3rem;
  padding: 0 1.5rem;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1.1rem;
}

/* ===== Hero card (first article with image) ===== */
.card-hero {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all 0.25s;
}
.card-hero:hover { box-shadow: var(--shadow-lg); border-color: var(--accent); }
.card-hero .hero-img {
  width: 100%; height: 100%; min-height: 280px; object-fit: cover;
}
.card-hero .hero-body {
  padding: 1.75rem; display: flex; flex-direction: column; justify-content: center;
}
.card-hero .card-title { font-size: 1.35rem; line-height: 1.3; margin-bottom: 0.6rem; }
.card-hero .card-summary { -webkit-line-clamp: 4; font-size: 0.92rem; }

/* ===== Card ===== */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: all 0.25s;
  display: flex; flex-direction: column;
}
.card:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); border-color: rgba(59,130,246,0.3); }

.card-img {
  width: 100%; height: 180px; object-fit: cover;
  background: var(--bg-pill);
}
.card-body { padding: 1.15rem; flex: 1; display: flex; flex-direction: column; }

.card-meta {
  display: flex; align-items: center; gap: 0.45rem;
  margin-bottom: 0.5rem; flex-wrap: wrap;
}
.badge {
  font-size: 0.68rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.04em; padding: 0.18rem 0.5rem;
  border-radius: 6px;
}
.badge-local { background: rgba(16,185,129,0.15); color: var(--accent-green); }
.badge-scotland { background: rgba(59,130,246,0.12); color: var(--accent); }
.badge-uk { background: rgba(245,158,11,0.12); color: var(--accent-amber); }

.card-source { font-size: 0.75rem; color: var(--text-secondary); font-weight: 500; }
.card-dot { color: var(--text-muted); font-size: 0.55rem; }
.card-time { font-size: 0.72rem; color: var(--text-muted); }

.card-title {
  font-size: 1rem; font-weight: 650; line-height: 1.35;
  margin-bottom: 0.45rem; color: var(--text);
}
.card-title a { color: inherit; }
.card-title a:hover { color: var(--accent); text-decoration: none; }

.card-summary {
  font-size: 0.85rem; color: var(--text-secondary);
  line-height: 1.55; flex: 1;
  display: -webkit-box; -webkit-line-clamp: 3;
  -webkit-box-orient: vertical; overflow: hidden;
}

.card-footer {
  padding: 0.65rem 1.15rem;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
}
.card-read {
  font-size: 0.78rem; font-weight: 600; color: var(--accent);
  display: flex; align-items: center; gap: 0.3rem;
}
.card-read:hover { text-decoration: none; opacity: 0.8; }
.card-author { font-size: 0.72rem; color: var(--text-muted); }

/* ===== Loading / Empty ===== */
.loading, .empty {
  text-align: center; padding: 4rem 1rem;
  color: var(--text-muted); font-size: 1rem;
}
.loading-spinner {
  display: inline-block; width: 28px; height: 28px;
  border: 3px solid var(--border); border-top-color: var(--accent);
  border-radius: 50%; animation: spin 0.8s linear infinite;
  margin-bottom: 0.8rem;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ===== Footer ===== */
.footer {
  text-align: center; padding: 1.5rem 1rem;
  color: var(--text-muted); font-size: 0.75rem;
  border-top: 1px solid var(--border);
}
.footer a { color: var(--text-secondary); }

/* ===== Responsive ===== */
@media (max-width: 900px) {
  .card-hero { grid-template-columns: 1fr; }
  .card-hero .hero-img { min-height: 200px; height: 200px; }
}
@media (max-width: 768px) {
  .grid { grid-template-columns: 1fr; gap: 0.9rem; padding: 0 1rem; }
  .header-inner { height: 52px; }
  .brand { font-size: 1.05rem; }
  .brand-sub { display: none; }
  .wispayr-link { display: none; }
  .toolbar { padding: 0 1rem; gap: 0.5rem; }
  .search-box input { width: 150px; }
  .search-box input:focus { width: 180px; }
  .stat-chip { padding: 0.25rem 0.5rem; font-size: 0.72rem; }
  .context-bar { padding: 0.5rem 1rem; }
}
@media (max-width: 480px) {
  .search-box { order: 10; width: 100%; }
  .search-box input, .search-box input:focus { width: 100%; }
  .context-inner { gap: 0.8rem; }
}
</style>
</head>
<body>

<!-- Warning Banner -->
<div class="warning-banner" id="warningBanner">
  <div class="banner-track" id="warningTrack"></div>
</div>

<!-- Header -->
<header class="header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-icon">📰</span>
      <div>
        AyrNews
        <div class="brand-sub">Ayrshire News Hub</div>
      </div>
    </a>
    <div class="header-right">
      <a href="https://ayrshire.wispayr.online" class="wispayr-link" target="_blank">WispAyr</a>
      <button class="icon-btn" onclick="toggleTheme()" title="Toggle theme" id="themeBtn">🌙</button>
    </div>
  </div>
</header>

<!-- Context Bar -->
<div class="context-bar" id="contextBar" style="display:none">
  <div class="context-inner" id="contextInner"></div>
</div>

<!-- Toolbar: stats + filters + search -->
<div class="toolbar">
  <div id="statsChips"></div>
  <div class="toolbar-spacer"></div>
  <button class="filter-btn active" data-cat="all">All</button>
  <button class="filter-btn" data-cat="local">Local</button>
  <button class="filter-btn" data-cat="scotland">Scotland</button>
  <button class="filter-btn" data-cat="uk">UK</button>
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="Search articles...">
  </div>
  <div class="refresh-info" id="refreshInfo"></div>
</div>

<!-- Articles Grid -->
<div class="grid" id="articlesGrid">
  <div class="loading" style="grid-column: 1/-1">
    <div class="loading-spinner"></div>
    <div>Loading Ayrshire news...</div>
  </div>
</div>

<!-- Footer -->
<footer class="footer">
  <p>AyrNews v2 — BBC Scotland, The Guardian, STV, Daily Record, Sky News & more.</p>
  <p style="margin-top:0.3rem">Part of <a href="https://ayrshire.wispayr.online" target="_blank">WispAyr Ayrshire</a> &middot; Powered by <a href="http://142.202.191.208:3882" target="_blank">Siphon</a> &middot; Auto-refreshes every 5 min</p>
</footer>

<script>
// ===== State =====
let articles = [];
let currentCategory = 'all';
let searchQuery = '';

// ===== Theme =====
function getTheme() { return localStorage.getItem('ayrnews-theme') || 'dark'; }
function applyTheme(t) {
  document.documentElement.setAttribute('data-theme', t);
  document.getElementById('themeBtn').textContent = t === 'dark' ? '\u2600\uFE0F' : '\uD83C\uDF19';
}
function toggleTheme() {
  const t = getTheme() === 'dark' ? 'light' : 'dark';
  localStorage.setItem('ayrnews-theme', t);
  applyTheme(t);
}
applyTheme(getTheme());

// ===== WMO weather code to description + icon =====
const WMO = {
  0: ['Clear sky', '\u2600\uFE0F'], 1: ['Mainly clear', '\uD83C\uDF24\uFE0F'], 2: ['Partly cloudy', '\u26C5'],
  3: ['Overcast', '\u2601\uFE0F'], 45: ['Fog', '\uD83C\uDF2B\uFE0F'], 48: ['Rime fog', '\uD83C\uDF2B\uFE0F'],
  51: ['Light drizzle', '\uD83C\uDF26\uFE0F'], 53: ['Drizzle', '\uD83C\uDF26\uFE0F'], 55: ['Dense drizzle', '\uD83C\uDF27\uFE0F'],
  56: ['Freezing drizzle', '\u2744\uFE0F'], 57: ['Heavy freezing drizzle', '\u2744\uFE0F'],
  61: ['Light rain', '\uD83C\uDF27\uFE0F'], 63: ['Rain', '\uD83C\uDF27\uFE0F'], 65: ['Heavy rain', '\uD83C\uDF27\uFE0F'],
  66: ['Freezing rain', '\u2744\uFE0F'], 67: ['Heavy freezing rain', '\u2744\uFE0F'],
  71: ['Light snow', '\uD83C\uDF28\uFE0F'], 73: ['Snow', '\uD83C\uDF28\uFE0F'], 75: ['Heavy snow', '\uD83C\uDF28\uFE0F'],
  77: ['Snow grains', '\uD83C\uDF28\uFE0F'], 80: ['Light showers', '\uD83C\uDF26\uFE0F'],
  81: ['Showers', '\uD83C\uDF27\uFE0F'], 82: ['Heavy showers', '\u26C8\uFE0F'],
  85: ['Light snow showers', '\uD83C\uDF28\uFE0F'], 86: ['Snow showers', '\uD83C\uDF28\uFE0F'],
  95: ['Thunderstorm', '\u26C8\uFE0F'], 96: ['Thunderstorm + hail', '\u26C8\uFE0F'], 99: ['Severe thunderstorm', '\u26C8\uFE0F'],
};

function weatherDesc(code) { return WMO[code] || ['Unknown', '\u2601\uFE0F']; }

// ===== Time Ago =====
function timeAgo(isoStr) {
  if (!isoStr) return '';
  const d = new Date(isoStr);
  const now = new Date();
  const secs = Math.floor((now - d) / 1000);
  if (secs < 60) return 'just now';
  const mins = Math.floor(secs / 60);
  if (mins < 60) return mins + 'm ago';
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return hrs + 'h ago';
  const days = Math.floor(hrs / 24);
  if (days === 1) return 'yesterday';
  if (days < 7) return days + 'd ago';
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function escHtml(s) {
  if (!s) return '';
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

// ===== Badge =====
function badgeHTML(cat, isLocal) {
  if (isLocal) return '<span class="badge badge-local">Local</span>';
  if (cat === 'scotland') return '<span class="badge badge-scotland">Scotland</span>';
  if (cat === 'uk') return '<span class="badge badge-uk">UK</span>';
  return '<span class="badge badge-scotland">Scotland</span>';
}

// ===== Hero Card =====
function heroCardHTML(a) {
  return '<article class="card-hero">' +
    '<img class="hero-img" src="' + escHtml(a.image_url) + '" alt="" loading="eager" onerror="this.style.display=\'none\'">' +
    '<div class="hero-body">' +
      '<div class="card-meta">' +
        badgeHTML(a.category, a.is_local) +
        '<span class="card-source">' + escHtml(a.source) + '</span>' +
        '<span class="card-dot">\u2022</span>' +
        '<span class="card-time">' + timeAgo(a.published_at) + '</span>' +
      '</div>' +
      '<h2 class="card-title"><a href="' + escHtml(a.link) + '" target="_blank" rel="noopener">' + escHtml(a.title) + '</a></h2>' +
      '<p class="card-summary">' + escHtml(a.summary) + '</p>' +
      '<div style="margin-top:1rem"><a class="card-read" href="' + escHtml(a.link) + '" target="_blank" rel="noopener">Read full story \u2192</a></div>' +
    '</div>' +
  '</article>';
}

// ===== Regular Card =====
function cardHTML(a) {
  const imgPart = a.image_url
    ? '<img class="card-img" src="' + escHtml(a.image_url) + '" alt="" loading="lazy" onerror="this.style.display=\'none\'">'
    : '';
  return '<article class="card">' +
    imgPart +
    '<div class="card-body">' +
      '<div class="card-meta">' +
        badgeHTML(a.category, a.is_local) +
        '<span class="card-source">' + escHtml(a.source) + '</span>' +
        '<span class="card-dot">\u2022</span>' +
        '<span class="card-time">' + timeAgo(a.published_at) + '</span>' +
      '</div>' +
      '<h3 class="card-title"><a href="' + escHtml(a.link) + '" target="_blank" rel="noopener">' + escHtml(a.title) + '</a></h3>' +
      '<p class="card-summary">' + escHtml(a.summary) + '</p>' +
    '</div>' +
    '<div class="card-footer">' +
      '<a class="card-read" href="' + escHtml(a.link) + '" target="_blank" rel="noopener">Read more \u2192</a>' +
      '<span class="card-author">' + escHtml(a.author || a.source) + '</span>' +
    '</div>' +
  '</article>';
}

// ===== Render Articles =====
function render() {
  const grid = document.getElementById('articlesGrid');
  let filtered = articles;

  if (currentCategory !== 'all') {
    if (currentCategory === 'local') {
      filtered = filtered.filter(a => a.is_local);
    } else {
      filtered = filtered.filter(a => a.category === currentCategory || (currentCategory === 'scotland' && a.is_local));
    }
  }

  if (searchQuery) {
    const q = searchQuery.toLowerCase();
    filtered = filtered.filter(a =>
      (a.title || '').toLowerCase().includes(q) ||
      (a.summary || '').toLowerCase().includes(q) ||
      (a.source || '').toLowerCase().includes(q)
    );
  }

  if (filtered.length === 0) {
    grid.innerHTML = '<div class="empty" style="grid-column:1/-1">No articles found. Try a different filter or check back soon.</div>';
    return;
  }

  // First article with image becomes the hero
  let heroIdx = filtered.findIndex(a => a.image_url);
  let html = '';
  if (heroIdx >= 0 && !searchQuery && currentCategory === 'all') {
    html += heroCardHTML(filtered[heroIdx]);
    filtered = filtered.filter((_, i) => i !== heroIdx);
  }
  html += filtered.map(cardHTML).join('');
  grid.innerHTML = html;
}

// ===== Render Stats =====
function renderStats(stats) {
  const chips = document.getElementById('statsChips');
  chips.innerHTML =
    '<div class="stat-chip"><span class="num">' + (stats.total || 0) + '</span><span class="lbl"> articles</span></div>' +
    '<div class="stat-chip"><span class="num">' + (stats.local || 0) + '</span><span class="lbl"> local</span></div>';

  const info = document.getElementById('refreshInfo');
  const lastRefresh = stats.last_refresh ? timeAgo(stats.last_refresh) : 'never';
  info.innerHTML = '<span class="pulse"></span> ' + lastRefresh;
}

// ===== Render Context Bar =====
function renderContext(ctx) {
  const bar = document.getElementById('contextBar');
  const inner = document.getElementById('contextInner');
  const parts = [];

  // Weather
  if (ctx.weather && ctx.weather.temp !== null) {
    const [desc, icon] = weatherDesc(ctx.weather.weather_code);
    parts.push(
      '<div class="ctx-item"><span class="ctx-icon">' + icon + '</span>' +
      '<span class="ctx-value">' + Math.round(ctx.weather.temp) + '\u00B0C</span>' +
      '<span class="ctx-label">' + desc + '</span></div>'
    );
    if (ctx.weather.wind_speed) {
      parts.push(
        '<div class="ctx-item"><span class="ctx-icon">\uD83D\uDCA8</span>' +
        '<span class="ctx-value">' + Math.round(ctx.weather.wind_speed) + '</span>' +
        '<span class="ctx-label">mph wind</span></div>'
      );
    }
    if (ctx.weather.wind_gusts && ctx.weather.wind_gusts > 30) {
      parts.push(
        '<div class="ctx-item"><span class="ctx-icon">\u26A0\uFE0F</span>' +
        '<span class="ctx-value">' + Math.round(ctx.weather.wind_gusts) + '</span>' +
        '<span class="ctx-label">mph gusts</span></div>'
      );
    }
  }

  // AQI
  if (ctx.aqi && ctx.aqi.index) {
    const aqiColors = { 'Low': 'var(--accent-green)', 'Moderate': 'var(--accent-amber)', 'High': 'var(--accent-red)', 'Very High': 'var(--accent-red)' };
    const color = aqiColors[ctx.aqi.band] || 'var(--text)';
    parts.push(
      '<div class="ctx-item"><span class="ctx-icon">\uD83C\uDF3F</span>' +
      '<span class="ctx-value" style="color:' + color + '">AQI ' + ctx.aqi.index + '</span>' +
      '<span class="ctx-label">' + (ctx.aqi.band || '') + '</span></div>'
    );
  }

  // Fuel
  if (ctx.fuel && ctx.fuel.petrol) {
    const pDir = ctx.fuel.petrol_change > 0 ? '\u2191' : ctx.fuel.petrol_change < 0 ? '\u2193' : '';
    parts.push(
      '<div class="ctx-item"><span class="ctx-icon">\u26FD</span>' +
      '<span class="ctx-value">' + ctx.fuel.petrol + 'p</span>' +
      '<span class="ctx-label">petrol ' + pDir + '</span></div>'
    );
  }

  // Traffic
  if (ctx.traffic_incidents > 0) {
    parts.push(
      '<div class="ctx-item"><span class="ctx-icon">\uD83D\uDE97</span>' +
      '<span class="ctx-value" style="color:var(--accent-amber)">' + ctx.traffic_incidents + '</span>' +
      '<span class="ctx-label">incidents</span></div>'
    );
  }

  if (parts.length > 0) {
    // Add Ayr label at front
    inner.innerHTML =
      '<div class="ctx-item"><span class="ctx-icon">\uD83C\uDFF4\uDB40\uDC67\uDB40\uDC62\uDB40\uDC73\uDB40\uDC63\uDB40\uDC74\uDB40\uDC7F</span><span class="ctx-label" style="font-weight:600;color:var(--text)">Ayr, Scotland</span></div>' +
      '<div class="ctx-sep"></div>' +
      parts.join('<div class="ctx-sep"></div>');
    bar.style.display = 'block';
  }

  // Warnings banner
  if (ctx.warnings && ctx.warnings.length > 0) {
    const banner = document.getElementById('warningBanner');
    const track = document.getElementById('warningTrack');
    const items = ctx.warnings.map(w => {
      const link = w.link ? ' <a href="' + escHtml(w.link) + '" target="_blank">View details</a>' : '';
      return '<span class="warn-icon">\u26A0\uFE0F</span> <span>MET OFFICE ' + escHtml(w.severity).toUpperCase() + ' WARNING: ' + escHtml(w.title) + ' \u2014 ' + escHtml(w.valid_from) + ' to ' + escHtml(w.valid_to) + link + '</span>';
    });
    // Duplicate for seamless scroll
    const content = items.join(' &nbsp;&nbsp;&nbsp; ');
    track.innerHTML = content + ' &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; ' + content;
    // Color by severity
    const hasRed = ctx.warnings.some(w => w.severity === 'red');
    const hasAmber = ctx.warnings.some(w => w.severity === 'amber');
    banner.classList.remove('warning-red');
    if (hasRed) banner.classList.add('warning-red');
    banner.classList.add('active');
  }
}

// ===== Fetch =====
async function fetchArticles() {
  try {
    const resp = await fetch('/api/articles?limit=100');
    const data = await resp.json();
    articles = data.articles || [];
    render();
  } catch (e) {
    console.error('Failed to fetch articles:', e);
  }
}

async function fetchStats() {
  try {
    const resp = await fetch('/api/stats');
    const data = await resp.json();
    renderStats(data);
  } catch (e) {
    console.error('Failed to fetch stats:', e);
  }
}

async function fetchContext() {
  try {
    const resp = await fetch('/api/context');
    const data = await resp.json();
    renderContext(data);
  } catch (e) {
    console.error('Failed to fetch context:', e);
  }
}

async function refresh() {
  await Promise.all([fetchArticles(), fetchStats(), fetchContext()]);
}

// ===== Events =====
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentCategory = btn.dataset.cat;
    render();
  });
});

document.getElementById('searchInput').addEventListener('input', (e) => {
  searchQuery = e.target.value.trim();
  render();
});

// ===== Init =====
refresh();
setInterval(refresh, 5 * 60 * 1000);
</script>
</body>
</html>
